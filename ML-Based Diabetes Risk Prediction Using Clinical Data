        "  ├─ Risk Score: {result['risk_score']}\n",
        "  ├─ Confidence: {result['confidence']}\n",
        "  └─ Probabilities:\n",
        "\"\"\")\n",
        "    for risk, prob in result['probabilities'].items():\n",
        "        print(f\"      • {risk}: {prob}\")"
